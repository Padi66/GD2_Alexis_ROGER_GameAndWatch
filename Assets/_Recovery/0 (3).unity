  introLines:
  - text: "Intrusion d\xE9tect\xE9e."
    speakerName: IA
    speakerPortrait: {fileID: 0}
  - text: Lancement des contre-mesures.
    speakerName: IA
    speakerPortrait: {fileID: 0}
  - text: "Tentative de piratage\u2026 inutile."
    speakerName: IA
    speakerPortrait: {fileID: 0}
  phase1Lines:
  - text: Tes algorithmes sont primitifs.
    speakerName: 
    speakerPortrait: {fileID: 0}
  phase2Lines:
  - text: "Mes d\xE9fenses\u2026 sont en train de tomber ?"
    speakerName: 
    speakerPortrait: {fileID: 0}
  phase3Lines:
  - text: "Impossible\u2026 je refuse d\u2019\xEAtre supprim\xE9 !"
    speakerName: 
    speakerPortrait: {fileID: 0}
  bossDefeatedLines:
  - text: "Erreur critique\u2026"
    speakerName: 
    speakerPortrait: {fileID: 0}
  - text: "Int\xE9grit\xE9 du noyau\u2026 12%\u2026 3%\u2026"
    speakerName: 
    speakerPortrait: {fileID: 0}
  - text: "Arr\xEAt du syst\xE8me."
    speakerName: 
    speakerPortrait: {fileID: 0}
